 } catch (err) {\n        console.error(\"Failed to parse URL:\", targetUrl, err);\n      }\n    }\n  };\n\n  return (\n    <div className=\"reading-pane\">\n      <header className=\"article-header\">\n        <h1>{item.title}</h1>\n        <div className=\"article-meta\">\n          <a\n            href={item.link}\n            onClick={(e) => {\n              e.preventDefault();\n              window.api.openExternal(item.link);\n            }}\n          >\n            View Original\n          </a>\n          <span>{new Date(item.pub_date).toLocaleString()}</span>\n        </div>\n      </header>\n\n      <div\n        className=\"article-content\"\n        dangerouslySetInnerHTML={{ __html: item.content }}\n        onClick={handleContentClick}\n      />\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\morinatsu\\projects\\FeedEater\\src\\components\\Sidebar.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\morinatsu\\projects\\FeedEater\\src\\context\\AppContext.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'err' is defined but never used.","line":33,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":33,"endColumn":17},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'err' is defined but never used.","line":43,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":43,"endColumn":17},{"ruleId":"react-refresh/only-export-components","severity":2,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","line":115,"column":14,"nodeType":"Identifier","messageId":"namedExport","endLine":115,"endColumn":27}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createContext, useContext, useState, useEffect } from \"react\";\nimport type { ReactNode } from \"react\";\nimport type { Feed, RSSItem } from \"../types\";\n\ninterface AppContextType {\n  feeds: Feed[];\n  items: RSSItem[];\n  selectedFeedId: number | null;\n  selectedItemId: string | null;\n  isLoading: boolean;\n  error: string | null;\n  setSelectedFeedId: (id: number | null) => void;\n  setSelectedItemId: (id: string | null) => void;\n  addFeed: (url: string) => Promise<void>;\n  markItemAsRead: (id: string) => Promise<void>;\n  refreshFeeds: () => Promise<void>;\n}\n\nconst AppContext = createContext<AppContextType | undefined>(undefined);\n\nexport const AppProvider = ({ children }: { children: ReactNode }) => {\n  const [feeds, setFeeds] = useState<Feed[]>([]);\n  const [items, setItems] = useState<RSSItem[]>([]);\n  const [selectedFeedId, setSelectedFeedId] = useState<number | null>(null);\n  const [selectedItemId, setSelectedItemId] = useState<string | null>(null);\n  const [isLoading, setIsLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  const loadFeeds = async () => {\n    try {\n      const data = await window.api.getFeeds();\n      setFeeds(data);\n    } catch (err) {\n      setError(\"Failed to load feeds\");\n    }\n  };\n\n  const loadItems = async (feedId?: number) => {\n    setIsLoading(true);\n    try {\n      const data = await window.api.getItems(feedId);\n      setItems(data);\n    } catch (err) {\n      setError(\"Failed to load items\");\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    loadFeeds();\n    loadItems(); // Initially load all items\n  }, []);\n\n  // When selected feed changes, reload items\n  useEffect(() => {\n    loadItems(selectedFeedId || undefined);\n    setSelectedItemId(null); // Reset item selection\n  }, [selectedFeedId]);\n\n  const addFeed = async (url: string) => {\n    setIsLoading(true);\n    setError(null);\n    try {\n      const result = await window.api.addFeed(url);\n      if (result.success) {\n        await loadFeeds();\n        // If it's the first feed, maybe select it\n        if (result.feed) {\n          setSelectedFeedId(result.feed.id);\n        }\n      } else {\n        setError(result.error || \"Failed to add feed\");\n      }\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const markItemAsRead = async (id: string) => {\n    try {\n      await window.api.markAsRead(id);\n      // Optimistically update UI\n      setItems((prevItems) =>\n        prevItems.map((item) =>\n          item.id === id ? { ...item, is_read: true } : item,\n        ),\n      );\n    } catch (err) {\n      console.error(\"Failed to mark as read\", err);\n    }\n  };\n\n  return (\n    <AppContext.Provider\n      value={{\n        feeds,\n        items,\n        selectedFeedId,\n        selectedItemId,\n        isLoading,\n        error,\n        setSelectedFeedId,\n        setSelectedItemId,\n        addFeed,\n        markItemAsRead,\n        refreshFeeds: loadFeeds,\n      }}\n    >\n      {children}\n    </AppContext.Provider>\n  );\n};\n\nexport const useAppContext = () => {\n  const context = useContext(AppContext);\n  if (context === undefined) {\n    throw new Error(\"useAppContext must be used within an AppProvider\");\n  }\n  return context;\n};\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\morinatsu\\projects\\FeedEater\\src\\main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\morinatsu\\projects\\FeedEater\\src\\types\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\morinatsu\\projects\\FeedEater\\test.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\morinatsu\\projects\\FeedEater\\vite.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
